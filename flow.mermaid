graph TD
    classDef repl fill:#B3E5FC,stroke:#01579B,stroke-width:2px,color:#000;
    classDef storage fill:#C8E6C9,stroke:#1B5E20,stroke-width:2px,color:#000;
    classDef node fill:#BBDEFB,stroke:#1565C0,stroke-width:1px,color:#000;
    classDef user fill:#FFE0B2,stroke:#E65100,stroke-width:2px,color:#000;
    classDef llm fill:#D1C4E9,stroke:#311B92,stroke-width:1px,color:#000;

    User((User)) -- "Terminal Input" --> REPL[Terminal REPL]

    subgraph LangGraph [LangGraph Orchestrator]
        direction TB
        EntryNode[Node: Entry<br/>load facts, summarize, trim]
        GenerateNode[Node: Generate<br/>call Ollama]
    end

    REPL -- "Invoke" --> EntryNode
    GenerateNode -- "Response" --> REPL

    EntryNode -.->|read / write state| MongoDB[(MongoDB<br/>Checkpoints)]
    GenerateNode -.->|invoke| Ollama[Ollama LLM]

    REPL -.->|every N turns| Diary[Background Diary<br/>extract facts]
    Diary -.->|update| MongoDB2[(MongoDB<br/>User Facts)]
    Diary -.->|summarize| Ollama

    class REPL repl;
    class MongoDB,MongoDB2 storage;
    class EntryNode,GenerateNode,Diary node;
    class User user;
    class Ollama llm;
